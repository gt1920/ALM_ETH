; *** Scatter-Loading Description File generated by uVision ***
; *************************************************************

LR_IROM1 0x08000000 0x00100000  {    ; load region size_region
  ER_IROM1 0x08000000 0x00100000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM1 0x20000000 0x00050000  {  ; SRAM1+SRAM2 (320KB) for general RW data
   .ANY (+RW +ZI)
  }
  ; ETH DMA descriptors + RX buffers in SRAM3 (non-cacheable via MPU)
  ; SRAM3: 0x20050000, size 320KB (0x50000)
  RW_ETH 0x20050000 UNINIT 0x00010000  {  ; 64KB for ETH DMA (plenty)
   *(.EthSection)
  }
}
