; *************************************************************
; *** Scatter-Loading Description - Bootloader (64KB)       ***
; *************************************************************

LR_IROM1 0x08000000 0x00010000  {    ; Bootloader: 64KB
  ER_IROM1 0x08000000 0x00010000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM1 0x20000000 0x00050000  {  ; SRAM1+SRAM2 (320KB)
   .ANY (+RW +ZI)
  }
}
