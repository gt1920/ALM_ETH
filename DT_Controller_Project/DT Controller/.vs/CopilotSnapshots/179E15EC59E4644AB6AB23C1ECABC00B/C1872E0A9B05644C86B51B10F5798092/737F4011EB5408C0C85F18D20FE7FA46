    // 新增：在设备插入时多次重试枚举（处理 WMI/系统注册滞后），使用同步 Invoke 启动枚举并读取列表长度
    private void StartArrivalRetry()
    {
        Task.Run(async () =>
        {
            const int attempts = 6;
            const int delayMs = 300;

            for (int i = 0; i < attempts; i++)
            {
                try
                {
                    // 在 UI 线程同步触发一次枚举（避免 BeginInvoke 的异步延迟）
                    if (this.IsHandleCreated && this.InvokeRequired)
                    {
                        this.Invoke((Action)(() => PopulateHidDevicesAsync()));
                    }
                    else
                    {
                        PopulateHidDevicesAsync();
                    }
                }
                catch
                {
                    // 忽略启动枚举的异常
                }

                await Task.Delay(delayMs).ConfigureAwait(false);

                try
                {
                    int count = 0;
                    if (this.IsHandleCreated && this.InvokeRequired)
                    {
                        count = (int)this.Invoke(new Func<int>(() => MainDevice.Items.Count));
                    }
                    else
                    {
                        count = MainDevice.Items.Count;
                    }

                    if (count > 0)
                        break; // 找到设备，停止重试
                }
                catch
                {
                    // 忽略读取 UI 时的异常，继续重试
                }
            }
        });
    }

